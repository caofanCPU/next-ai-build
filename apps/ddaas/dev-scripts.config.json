{
  "i18n": {
    "locales": ["en", "zh"],
    "defaultLocale": "en",
    "messageRoot": "messages"
  },
  "scan": {
    "include": ["src/**/*.{tsx,ts,jsx,js}"],
    "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/**/*.d.ts", "node_modules/**"]
  },
  "blog": {
    "mdxDir": "src/mdx/blog",
    "outputFile": "index.mdx",
    "metaFile": "meta.json",
    "iocSlug": "ioc",
    "prefix": "blog"
  },
  "output": {
    "logDir": "logs",
    "verbose": false
  },
  "diaomaoUpdate": {
    "sourceUrl": "https://raw.githubusercontent.com/caofanCPU/next-ai-build/main/pnpm-workspace.yaml",
    "allowedPackages": [
      "@clerk/localizations",
      "@clerk/nextjs",
      "@clerk/shared",
      "@clerk/themes",
      "@prisma/client",
      "@tailwindcss/cli",
      "@tailwindcss/postcss",
      "fumadocs-core",
      "fumadocs-docgen",
      "fumadocs-mdx",
      "fumadocs-typescript",
      "fumadocs-ui",
      "mermaid",
      "next",
      "next-intl",
      "next-themes",
      "prisma",
      "react",
      "react-dom",
      "stripe",
      "tailwindcss"
    ],
    "compactLog": true
  },
  "architectureConfig": {
    ".": "DDAAS项目"
  }
}
