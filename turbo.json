{
  "$schema": "https://v2-9-6.turborepo.dev/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "TURBO_TELEMETRY_DISABLED",
    "TURBO_TOKEN",
    "TURBO_TEAM"
  ],
  "tasks": {
    "copy-shared-assets": {
      "cache": true,
      "inputs": ["packages/shared-assets/public/**", "packages/shared-assets/scripts/**"],
      "outputs": ["../../apps/*/public/shared/**"],
      "env": ["NODE_ENV"]
    },
    "build": {
      "dependsOn": ["^build", "@windrun-huaiin/shared-assets#copy-shared-assets"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NODE_ENV",
        "NEXT_PUBLIC_*",
        "CLERK_SECRET_KEY",
        "CLERK_DEBUG",
        "NEXT_PUBLIC_CLERK_*",
        "DATABASE_URL",
        "CLERK_WEBHOOK_SECRET",
        "ENABLE_STRIPE_SUBSCRIPTION_UPGRADE",
        "SHOW_FINGERPRINT_STATUS",
        "ACTIVE_PAYMENT_PROVIDER",
        "OPENROUTER_*",
        "MONEY_PRICE_*",
        "CREDITS_*",
        "STRIPE_*",
        "UPSTASH_REDIS_*",
        "QSTASH_*"
      ]
    },
    "build:prod": {
      "dependsOn": ["^build:prod", "@windrun-huaiin/shared-assets#copy-shared-assets"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NODE_ENV",
        "NEXT_PUBLIC_*",
        "CLERK_SECRET_KEY",
        "CLERK_DEBUG",
        "NEXT_PUBLIC_CLERK_*",
        "DATABASE_URL",
        "CLERK_WEBHOOK_SECRET",
        "ENABLE_STRIPE_SUBSCRIPTION_UPGRADE",
        "SHOW_FINGERPRINT_STATUS",
        "ACTIVE_PAYMENT_PROVIDER",
        "OPENROUTER_*",
        "MONEY_PRICE_*",
        "CREDITS_*",
        "STRIPE_*",
        "UPSTASH_REDIS_*",
        "QSTASH_*"
      ]
    },
    "@windrun-huaiin/shared-assets#build": {
      "cache": false,
      "outputs": [],
      "env": ["NODE_ENV"]
    },
    "@windrun-huaiin/shared-assets#copy-shared-assets": {
      "cache": true,
      "inputs": ["packages/shared-assets/public/**", "packages/shared-assets/scripts/**"],
      "outputs": ["../../apps/*/public/shared/**"],
      "env": ["NODE_ENV"]
    },
    "@windrun-huaiin/dev-scripts#build": {
      "outputs": ["dist/**"],
      "env": ["NODE_ENV"]
    },
    "@windrun-huaiin/lib#build": {
      "outputs": ["dist/**"],
      "env": ["NODE_ENV"]
    },
    "@windrun-huaiin/fumadocs-local-md#build": {
      "dependsOn": ["@windrun-huaiin/contracts#build"],
      "outputs": ["dist/**"],
      "env": ["NODE_ENV", "LOCAL_MD_CACHE_DISABLE"]
    },
    "@windrun-huaiin/contracts#build": {
      "outputs": ["dist/**"],
      "env": ["NODE_ENV"]
    },
    "@windrun-huaiin/backend-core#build": {
      "dependsOn": [
        "@windrun-huaiin/contracts#build",
        "@windrun-huaiin/lib#build",
        "@windrun-huaiin/base-ui#build",
        "@windrun-huaiin/third-ui#build"
      ],
      "outputs": ["dist/**"],
      "env": [
        "NODE_ENV",
        "CLERK_SECRET_KEY",
        "CLERK_DEBUG",
        "NEXT_PUBLIC_CLERK_*",
        "DATABASE_URL",
        "CLERK_WEBHOOK_SECRET",
        "ENABLE_STRIPE_SUBSCRIPTION_UPGRADE",
        "SHOW_FINGERPRINT_STATUS",
        "ACTIVE_PAYMENT_PROVIDER",
        "OPENROUTER_*",
        "MONEY_PRICE_*",
        "CREDITS_*",
        "STRIPE_*",
        "UPSTASH_REDIS_*",
        "QSTASH_*"
      ]
    },
    "@windrun-huaiin/base-ui#build": {
      "dependsOn": ["@windrun-huaiin/lib#build"],
      "outputs": ["dist/**"],
      "env": ["NODE_ENV"]
    },
    "@windrun-huaiin/third-ui#build": {
      "dependsOn": [
        "@windrun-huaiin/contracts#build",
        "@windrun-huaiin/base-ui#build",
        "@windrun-huaiin/lib#build"
      ],
      "outputs": ["dist/**"],
      "env": [
        "NODE_ENV",
        "OPENROUTER_*",
        "CLERK_SECRET_KEY",
        "CLERK_DEBUG",
        "NEXT_PUBLIC_CLERK_*",
        "DATABASE_URL",
        "CLERK_WEBHOOK_SECRET",
        "ENABLE_STRIPE_SUBSCRIPTION_UPGRADE",
        "SHOW_FINGERPRINT_STATUS",
        "ACTIVE_PAYMENT_PROVIDER",
        "MONEY_PRICE_*",
        "CREDITS_*",
        "STRIPE_*",
        "UPSTASH_REDIS_*",
        "QSTASH_*"
      ]
    },
    "@windrun-huaiin/dev-scripts#build:prod": {
      "outputs": ["dist/**"],
      "env": ["NODE_ENV"]
    },
    "@windrun-huaiin/lib#build:prod": {
      "outputs": ["dist/**"],
      "env": ["NODE_ENV"]
    },
    "@windrun-huaiin/fumadocs-local-md#build:prod": {
      "dependsOn": ["@windrun-huaiin/contracts#build:prod"],
      "outputs": ["dist/**"],
      "env": ["NODE_ENV", "LOCAL_MD_CACHE_DISABLE"]
    },
    "@windrun-huaiin/contracts#build:prod": {
      "outputs": ["dist/**"],
      "env": ["NODE_ENV"]
    },
    "@windrun-huaiin/backend-core#build:prod": {
      "dependsOn": [
        "@windrun-huaiin/contracts#build:prod",
        "@windrun-huaiin/lib#build:prod",
        "@windrun-huaiin/base-ui#build:prod",
        "@windrun-huaiin/third-ui#build:prod"
      ],
      "outputs": ["dist/**"],
      "env": [
        "NODE_ENV",
        "CLERK_SECRET_KEY",
        "CLERK_DEBUG",
        "NEXT_PUBLIC_CLERK_*",
        "DATABASE_URL",
        "CLERK_WEBHOOK_SECRET",
        "ENABLE_STRIPE_SUBSCRIPTION_UPGRADE",
        "SHOW_FINGERPRINT_STATUS",
        "ACTIVE_PAYMENT_PROVIDER",
        "OPENROUTER_*",
        "MONEY_PRICE_*",
        "CREDITS_*",
        "STRIPE_*",
        "UPSTASH_REDIS_*",
        "QSTASH_*"
      ]
    },
    "@windrun-huaiin/base-ui#build:prod": {
      "dependsOn": ["@windrun-huaiin/lib#build:prod"],
      "outputs": ["dist/**"],
      "env": ["NODE_ENV"]
    },
    "@windrun-huaiin/third-ui#build:prod": {
      "dependsOn": [
        "@windrun-huaiin/contracts#build:prod",
        "@windrun-huaiin/base-ui#build:prod",
        "@windrun-huaiin/lib#build:prod"
      ],
      "outputs": ["dist/**"],
      "env": [
        "NODE_ENV",
        "OPENROUTER_*",
        "CLERK_SECRET_KEY",
        "CLERK_DEBUG",
        "NEXT_PUBLIC_CLERK_*",
        "DATABASE_URL",
        "CLERK_WEBHOOK_SECRET",
        "ENABLE_STRIPE_SUBSCRIPTION_UPGRADE",
        "SHOW_FINGERPRINT_STATUS",
        "ACTIVE_PAYMENT_PROVIDER",
        "MONEY_PRICE_*",
        "CREDITS_*",
        "STRIPE_*",
        "UPSTASH_REDIS_*",
        "QSTASH_*"
      ]
    },
    "@windrun-huaiin/shared-assets#build:prod": {
      "cache": false,
      "outputs": [],
      "env": ["NODE_ENV"]
    },
    "dev": {
      "dependsOn": ["copy-shared-assets"],
      "cache": false,
      "persistent": true,
      "env": [
        "NODE_ENV",
        "NEXT_PUBLIC_*",
        "CLERK_SECRET_KEY",
        "CLERK_DEBUG",
        "DATABASE_URL",
        "CLERK_WEBHOOK_SECRET",
        "ENABLE_STRIPE_SUBSCRIPTION_UPGRADE",
        "SHOW_FINGERPRINT_STATUS",
        "ACTIVE_PAYMENT_PROVIDER",
        "OPENROUTER_*",
        "MONEY_PRICE_*",
        "CREDITS_*",
        "STRIPE_*",
        "UPSTASH_REDIS_*",
        "QSTASH_*"
      ]
    },
    "lint": {
      "outputs": [],
      "env": ["NODE_ENV"]
    },
    "type-check": {
      "outputs": [],
      "env": ["NODE_ENV"]
    }
  }
}
