{
  "name": "@windrun-huaiin/fumadocs-local-md",
  "version": "26.0.2",
  "description": "A compatibility-focused local Markdown source package based on @fumadocs/local-md",
  "keywords": [
    "Docs",
    "fumadocs"
  ],
  "homepage": "https://github.com/caofanCPU/next-ai-build",
  "license": "MIT",
  "author": "windrun-huaiin",
  "repository": {
    "type": "git",
    "url": "https://github.com/caofanCPU/next-ai-build.git",
    "directory": "packages/local-md"
  },
  "files": [
    "dist",
    "bin"
  ],
  "bin": {
    "local-md": "./bin/local-md.mjs"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli.js",
    "./core": "./dist/core.js",
    "./server": "./dist/server/index.js",
    "./server/source": "./dist/server/source-entry.js",
    "./server/features": "./dist/server/features.js",
    "./server/features/code": "./dist/server/features/code.js",
    "./server/features/math": "./dist/server/features/math.js",
    "./server/features/npm": "./dist/server/features/npm.js",
    "./server/features/steps": "./dist/server/features/steps.js",
    "./presets/fuma-docs": "./dist/presets/fuma-docs.js",
    "./presets/fuma-docs/base": "./dist/presets/fuma-docs-base.js",
    "./presets/fuma-docs/features/code": "./dist/presets/fuma-docs-features/code.js",
    "./presets/fuma-docs/features/math": "./dist/presets/fuma-docs-features/math.js",
    "./presets/fuma-docs/features/npm": "./dist/presets/fuma-docs-features/npm.js",
    "./js/executor": "./dist/js/executor.js",
    "./js/executor-native": "./dist/js/executor-native.js",
    "./js/executor-virtual": "./dist/js/executor-virtual.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm types:check && tsdown",
    "build:prod": "pnpm types:check && tsdown",
    "clean": "rm -rf dist",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@mdx-js/mdx": "catalog:",
    "@standard-schema/spec": "catalog:",
    "estree-util-build-jsx": "catalog:",
    "estree-util-to-js": "catalog:",
    "hast-util-to-jsx-runtime": "catalog:",
    "rehype-katex": "catalog:",
    "remark": "catalog:",
    "remark-math": "catalog:",
    "remark-rehype": "catalog:",
    "shiki": "catalog:",
    "tinyglobby": "catalog:",
    "unified": "catalog:",
    "vfile": "catalog:",
    "yaml": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/estree": "catalog:",
    "@types/estree-jsx": "catalog:",
    "@types/hast": "catalog:",
    "@types/mdast": "catalog:",
    "@types/mdx": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/unist": "catalog:",
    "fumadocs-core": "catalog:",
    "react": "catalog:",
    "tsdown": "catalog:",
    "tslib": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@types/estree": "*",
    "@types/estree-jsx": "*",
    "@types/hast": "*",
    "@types/mdx": "*",
    "@types/react": "*",
    "@types/unist": "*",
    "fumadocs-core": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "peerDependenciesMeta": {
    "@types/mdx": {
      "optional": true
    },
    "@types/estree": {
      "optional": true
    },
    "@types/estree-jsx": {
      "optional": true
    },
    "@types/hast": {
      "optional": true
    },
    "@types/unist": {
      "optional": true
    },
    "@types/react": {
      "optional": true
    }
  }
}
