{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "outDir": "./dist",
    "declaration": true,
    "declarationDir": "./dist",
    "incremental": false,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": "./src",
    "paths": {
      "@core/*": ["./*"],
      "@core/db": ["./services/database"],
      "@core/db/*": ["./services/database/*"],
      "@core/aggregate/*": ["./services/aggregate/*"],
      "@core/context/*": ["./services/context/*"],
      "@core/stripe/*": ["./services/stripe/*"],
      "@core/lib/*": ["./lib/*"],
      "@core/auth/*": ["./auth/*"],
      "@core/prisma/*": ["./prisma/*"],
      "@backend-core/*": ["./*"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
