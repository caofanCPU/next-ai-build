{
  "i18n": {
    "locales": ["en", "zh", "ja"],
    "defaultLocale": "en",
    "messageRoot": "messages"
  },
  "scan": {
    "include": ["src/**/*.{tsx,ts,jsx,js}"],
    "exclude": ["src/**/*.test.ts", "src/**/*.d.ts", "node_modules/**"]
  },
  "blog": {
    "mdxDir": "src/mdx/blog",
    "outputFile": "index.mdx",
    "metaFile": "meta.json",
    "iocSlug": "ioc",
    "prefix": "blog"
  },
  "output": {
    "logDir": "scripts",
    "verbose": false
  },
  "diaomaoUpdate": {
    "sourceUrl": "https://raw.githubusercontent.com/caofanCPU/next-ai-build/main/pnpm-workspace.yaml",
    "allowedPackages": [
      "@clerk/nextjs",
      "@clerk/themes",
      "@prisma/client",
      "next",
      "react",
      "react-dom",
      "stripe"
    ],
    "compactLog": true
  },
  "architectureConfig": {
    ".": "RootProject"
  }
}
